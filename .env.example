# Источник данных: "mock" (по умолчанию) или "api".
VITE_DATA_SOURCE=mock

# Базовый URL backend. Обязателен при VITE_DATA_SOURCE=api.
# Если оставить пустым в api-режиме, UI покажет нормализованную ошибку
# (API_NOT_CONFIGURED), но не упадёт в белый экран.
VITE_API_BASE_URL=

# Таймаут одного HTTP-запроса в миллисекундах (по умолчанию 15000).
VITE_API_TIMEOUT_MS=15000

# Параметры mock-режима (для разработки UI).
VITE_MOCK_LATENCY_MS=250
VITE_MOCK_CHECK_DURATION_MS=5000
